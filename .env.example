# Same MySQL the GardenRankings plugin writes to (DatabaseProvider = MySql).
DATABASE_URL="mysql://user:password@your-db-host:3306/gardenrankings"

# Shown on the connect button (ip:port).
NEXT_PUBLIC_SERVER_ADDRESS="203.0.113.10:27015"

# --- Inventory simulator (Steam login + in-game sync) ---

# Secret used to sign the login session cookie. Generate one, e.g.:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of this site. Used for the Steam OpenID realm/return.
# Optional locally (falls back to the request origin); set it in production.
SITE_URL="https://garden-retakes.example.com"

# Optional: enables fetching the player's Steam name + avatar after login.
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# Optional: override where skin/sticker images are served from. Defaults to
# cs2-lib's CDN (https://cdn.cstrike.app). A mirror that needs no self-hosting:
#   https://cdn.jsdelivr.net/gh/ianlucas/cs2-lib-assets@main
# NEXT_PUBLIC_ASSETS_BASE_URL="https://cdn.cstrike.app"

# Shared secret between the Garden-inventory plugin (invsim_apikey) and this site
# (used by /loadout and StatTrak increments).
INVSIM_API_KEY="change-me"
