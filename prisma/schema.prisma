// Maps directly onto the tables created by GardenRankings (EF Core).
// Point DATABASE_URL at the same MySQL the plugin uses
// (DatabaseProvider = MySql in the plugin config).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Season {
  Id           Int       @id @default(autoincrement())
  Name         String
  StartedAtUtc DateTime
  EndedAtUtc   DateTime?
  IsActive     Boolean

  @@map("Seasons")
}

model PlayerProfile {
  SteamId        BigInt   @id
  LastKnownName  String
  FirstSeenAtUtc DateTime
  LastSeenAtUtc  DateTime

  @@map("PlayerProfiles")
}

model PlayerSeasonStats {
  Id                   Int       @id @default(autoincrement())
  SeasonId             Int
  SteamId              BigInt
  Elo                  Int
  PeakElo              Int
  RankedRoundsPlayed   Int
  RankedRoundsWon      Int
  UnrankedRoundsPlayed Int
  LastRankedRoundAtUtc DateTime?
  UpdatedAtUtc         DateTime

  @@unique([SeasonId, SteamId])
  @@map("PlayerSeasonStats")
}

model PlayerRoundRecord {
  Id                 BigInt   @id @default(autoincrement())
  RoundRecordId      BigInt
  SeasonId           Int
  Map                String
  PlayedAtUtc        DateTime
  IsRanked           Boolean
  SteamId            BigInt
  PlayerName         String
  TeamNum            Int
  WonRound           Boolean
  Kills              Int
  Headshots          Int
  Assists            Int
  FlashAssists       Int
  Damage             Int
  UtilityDamage      Int
  EnemiesFlashed     Int
  EnemyBlindDuration Float
  Died               Boolean
  DiedAtSeconds      Float?
  WasTeamKilled      Boolean
  KilledTeammate     Boolean
  DiedEarly          Boolean
  OpeningKill        Boolean
  OpeningDeath       Boolean
  TradeKills         Int
  TradedDeath        Boolean
  Kast               Boolean
  MultiKillCount     Int
  ClutchVersus       Int
  ClutchWon          Boolean
  BombPlanted        Boolean
  BombDefused        Boolean
  WasAfk             Boolean
  Rating             Float
  EloDelta           Int
  EloAfter           Int

  @@index([SteamId, PlayedAtUtc])
  @@index([SeasonId, SteamId])
  @@map("PlayerRoundRecords")
}

model CrTeamStats {
  Id            Int      @id @default(autoincrement())
  SeasonId      Int
  TeamKey       String
  PlayerNames   String
  TeamSize      Int
  Elo           Int
  PeakElo       Int
  MatchesPlayed Int
  MatchesWon    Int
  MatchesDrawn  Int
  RoundsWon     Int
  RoundsLost    Int
  UpdatedAtUtc  DateTime

  @@unique([SeasonId, TeamKey])
  @@map("CrTeamStats")
}

// Website-owned: a player's saved inventory simulator loadouts (JSON blob),
// keyed by SteamID64. Served to the CS2 inventory-simulator plugin.
model WebInventory {
  SteamId   BigInt   @id
  Data      String   @db.LongText
  UpdatedAt DateTime @updatedAt

  @@map("WebInventories")
}

// Garden (W2): bans, display-name overrides, web profiles.
model GardenBan {
  SteamId     BigInt    @id
  Name        String
  Reason      String
  BannedBy    BigInt
  BannedAtUtc DateTime
  ExpiresAtUtc DateTime?

  @@map("GardenBans")
}

model GardenNameOverride {
  SteamId BigInt @id
  Name    String

  @@map("GardenNameOverrides")
}

model GardenWebProfile {
  SteamId   BigInt   @id
  AvatarUrl String?
  Bio       String?
  Country   String?
  UpdatedAt DateTime @updatedAt

  @@map("GardenWebProfiles")
}

// Garden-retakes merged plugin (Duels mode): one row per completed 1v1.
model DuelRecord {
  Id             BigInt   @id @default(autoincrement())
  SeasonId       Int
  Map            String
  PlayedAtUtc    DateTime
  ArenaName      String
  WinnerSteamId  BigInt
  WinnerName     String
  LoserSteamId   BigInt
  LoserName      String
  IsChallenge    Boolean
  ChallengeScore String

  @@index([SeasonId])
  @@map("DuelRecords")
}

// Garden-retakes merged plugin (R3): admin storage + audit log.
model GardenAdmin {
  SteamId    BigInt   @id
  Name       String
  Level      Int
  AddedBy    BigInt
  AddedAtUtc DateTime

  @@map("GardenAdmins")
}

model GardenAdminLogEntry {
  Id            BigInt   @id @default(autoincrement())
  AtUtc         DateTime
  ActorSteamId  BigInt
  ActorName     String
  Action        String
  TargetSteamId BigInt
  TargetName    String
  Detail        String

  @@map("GardenAdminLog")
}

model CrMatch {
  Id           BigInt    @id @default(autoincrement())
  SeasonId     Int
  Map          String
  StartedAtUtc DateTime
  EndedAtUtc   DateTime?
  TeamAKey     String
  TeamBKey     String
  TeamAName    String
  TeamBName    String
  TeamSize     Int
  ScoreA       Int
  ScoreB       Int
  Result       String
  EloDeltaA    Int
  EloDeltaB    Int

  @@index([SeasonId])
  @@map("CrMatches")
}
